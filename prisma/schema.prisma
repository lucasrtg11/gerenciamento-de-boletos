generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Boleto {
  id               String        @id @default(cuid())
  numeroBoleto     String?          @unique
  clienteNome      String
  pagadorNome      String?
  seuNumero        String?
  nossoNumero      String?
  valorCentavos    Int
  dataVencimento   DateTime
  status           StatusBoleto  @default(ABERTO)
  pagadorDocumento String?
  pagadorEmail     String?
  pagadorTelefone  String?
  pagadorEndereco  String?
  pagadorCidade    String?
  pagadorUF        String?
  pagadorCEP       String?
  linhaDigitavel   String?
  codigoBarras     String?
  pdfUrl           String?
  criadoEm         DateTime      @default(now())
  dataEmissao      DateTime      @default(now())
  atualizadoEm     DateTime      @updatedAt
  notificacoes     Notificacao[]
}

model Notificacao {
  id        String          @id @default(cuid())
  boletoId  String
  tipo      NotificacaoTipo
  enviadoEm DateTime        @default(now())
  destino   String
  boleto    Boleto          @relation(fields: [boletoId], references: [id], onDelete: Cascade)

  @@index([boletoId])
}

model Config {
  id              Int      @id @default(1)
  telefoneDono    String
  horaEnvioResumo String   @default("08:00")
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
}

model User {
  id           String   @id @default(cuid())
  nome         String   @unique
  email        String?  @unique
  passwordHash String
  role         Role
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  dataEmissao  DateTime @default(now())
}

enum StatusBoleto {
  ABERTO
  PAGO
  CANCELADO
}

enum NotificacaoTipo {
  NOVO
  VENCE_HOJE
  VENCE_AMANHA
  ATRASADO
  PAGO
  CANCELADO
}

enum Role {
  ADMIN
  DONO
  OPERADOR
}
