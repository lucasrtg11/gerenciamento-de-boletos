generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatusBoleto {
  ABERTO
  PAGO
  CANCELADO
}

enum NotificacaoTipo {
  NOVO
  VENCE_HOJE
  VENCE_AMANHA
  ATRASADO
  PAGO
  CANCELADO
}

model Boleto {
  id               String       @id @default(cuid())

  // Campo antigo (mantemos por enquanto para NÃO perder dados)
  clienteNome      String

  // Novo campo (vai virar obrigatório depois que migrarmos os dados)
  pagadorNome      String?

  // Identificadores (para integração Sicoob)
  seuNumero        String?
  nossoNumero      String?

  // Dados financeiros
  valorCentavos    Int
  dataVencimento   DateTime
  status           StatusBoleto @default(ABERTO)

  // Dados do pagador
  pagadorDocumento String?      // CPF/CNPJ
  pagadorEmail     String?
  pagadorTelefone  String?

  pagadorEndereco  String?
  pagadorCidade    String?
  pagadorUF        String?
  pagadorCEP       String?

  // Dados do boleto (retornados pelo banco)
  linhaDigitavel   String?
  codigoBarras     String?
  pdfUrl           String?

  // Controle
  criadoEm         DateTime     @default(now())
  dataEmissao      DateTime     @default(now())
  atualizadoEm     DateTime     @updatedAt

  notificacoes     Notificacao[]
}

model Notificacao {
  id         String           @id @default(cuid())
  boletoId   String
  tipo       NotificacaoTipo
  enviadoEm  DateTime         @default(now())
  destino    String

  boleto     Boleto           @relation(fields: [boletoId], references: [id], onDelete: Cascade)

  @@index([boletoId])
}

model Config {
  id              Int      @id @default(1)
  telefoneDono    String
  horaEnvioResumo String   @default("08:00")

  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
}
enum Role {
  ADMIN
  DONO
  OPERADOR
}

model User {
  id           String   @id @default(cuid())
  nome         String   @unique
  email        String?  @unique
  passwordHash String
  role         Role
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  dataEmissao DateTime @default(now())
}
